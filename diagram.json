{
  "version": 1,
  "author": "mc-hammer",
  "editor": "wokwi",
  "parts": [
    {
      "id": "mega",
      "type": "wokwi-arduino-mega",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "id": "oled",
      "type": "board-ssd1306",
      "top": 0,
      "left": 420,
      "attrs": { "i2cAddress": "0x3c" }
    },
    {
      "id": "enc_pos",
      "type": "wokwi-ky-040",
      "top": 0,
      "left": 220,
      "attrs": {}
    },
    {
      "id": "enc_force",
      "type": "wokwi-ky-040",
      "top": 120,
      "left": 220,
      "attrs": {}
    },
    {
      "id": "enc_int",
      "type": "wokwi-ky-040",
      "top": 240,
      "left": 220,
      "attrs": {}
    },
    {
      "id": "sw_hit",
      "type": "wokwi-slide-switch",
      "top": 360,
      "left": 220,
      "attrs": { "bounce": "0" }
    },
    {
      "id": "sw_pwr",
      "type": "wokwi-slide-switch",
      "top": 420,
      "left": 220,
      "attrs": { "bounce": "0" }
    },
    {
      "id": "btn_zero",
      "type": "wokwi-pushbutton",
      "top": 360,
      "left": 320,
      "attrs": { "label": "ZERO", "color": "green", "bounce": "0" }
    },
    {
      "id": "drv",
      "type": "wokwi-a4988",
      "top": 0,
      "left": 620,
      "attrs": {}
    },
    {
      "id": "mot",
      "type": "wokwi-stepper-motor",
      "top": 120,
      "left": 620,
      "attrs": { "size": "34", "display": "angle", "arrow": "orange" }
    }
  ],
  "connections": [
    ["oled:GND", "mega:GND", "black", []],
    ["oled:VCC", "mega:5V", "red", []],
    ["oled:SDA", "mega:20", "green", []],
    ["oled:SCL", "mega:21", "green", []],

    ["enc_pos:GND", "mega:GND", "black", []],
    ["enc_pos:VCC", "mega:5V", "red", []],
    ["enc_pos:CLK", "mega:2", "gold", []],
    ["enc_pos:DT", "mega:3", "gold", []],

    ["enc_force:GND", "mega:GND", "black", []],
    ["enc_force:VCC", "mega:5V", "red", []],
    ["enc_force:CLK", "mega:4", "gold", []],
    ["enc_force:DT", "mega:5", "gold", []],
    ["enc_force:SW", "mega:6", "gold", []],

    ["enc_int:GND", "mega:GND", "black", []],
    ["enc_int:VCC", "mega:5V", "red", []],
    ["enc_int:CLK", "mega:7", "gold", []],
    ["enc_int:DT", "mega:8", "gold", []],
    ["enc_int:SW", "mega:9", "gold", []],

    ["sw_hit:1", "mega:GND", "black", []],
    ["sw_hit:3", "mega:5V", "red", []],
    ["sw_hit:2", "mega:10", "blue", []],

    ["sw_pwr:1", "mega:GND", "black", []],
    ["sw_pwr:3", "mega:5V", "red", []],
    ["sw_pwr:2", "mega:12", "blue", []],

    ["btn_zero:1.r", "mega:11", "green", []],
    ["btn_zero:2.r", "mega:GND", "black", []],

    ["drv:GND", "mega:GND", "black", []],
    ["drv:VDD", "mega:5V", "red", []],
    ["drv:STEP", "mega:A0", "orange", []],
    ["drv:DIR", "mega:A1", "orange", []],
    ["drv:ENABLE", "mega:A2", "orange", []],
    ["drv:RESET", "drv:SLEEP", "gray", []],

    ["mot:A+", "drv:2A", "blue", []],
    ["mot:A-", "drv:2B", "blue", []],
    ["mot:B+", "drv:1A", "blue", []],
    ["mot:B-", "drv:1B", "blue", []]
  ],
  "serialMonitor": { "display": "auto", "newline": "lf" }
}
